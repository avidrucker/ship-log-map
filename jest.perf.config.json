{
  "testEnvironment": "jsdom",
  "globals": {
    "__DEV__": true
  },
  "transform": {},
  "testMatch": [
    "<rootDir>/src/perf/**/*.bench.test.js"
  ],
  "testPathIgnorePatterns": ["<rootDir>/node_modules/"],
  "setupFilesAfterEnv": ["<rootDir>/src/setupTests.js"],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
